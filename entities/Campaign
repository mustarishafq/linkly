{
  "name": "Campaign",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Campaign name"
    },
    "description": {
      "type": "string",
      "description": "Campaign description"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "completed"
      ],
      "default": "active"
    },
    "start_date": {
      "type": "string",
      "format": "date-time"
    },
    "end_date": {
      "type": "string",
      "format": "date-time"
    },
    "total_clicks": {
      "type": "number",
      "default": 0
    },
    "unique_visitors": {
      "type": "number",
      "default": 0
    },
    "total_conversions": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name"
  ]
}